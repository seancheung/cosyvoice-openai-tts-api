# ---------- builder ----------
FROM continuumio/miniconda3:24.7.1-0 AS builder

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

RUN apt-get update && apt-get install -y --no-install-recommends \
        git build-essential wget unzip ca-certificates libsox-dev \
    && rm -rf /var/lib/apt/lists/*

RUN conda install -y -c conda-forge python=3.10 pynini==2.1.5 \
    && conda clean -afy

# openai-whisper==20231117's setup.py imports pkg_resources, which setuptools
# 81+ no longer ships. Pin below that and build it without isolation so it
# sees this setuptools instead of pip's fresh build env.
RUN pip install --no-cache-dir --upgrade pip "setuptools<81" wheel

RUN pip install --no-cache-dir --index-url https://download.pytorch.org/whl/cpu \
        torch==2.3.1 torchaudio==2.3.1

COPY CosyVoice /opt/CosyVoice
COPY docker/requirements.cpu.txt /tmp/requirements.cpu.txt

RUN pip install --no-cache-dir --no-build-isolation openai-whisper==20231117 \
    && pip install --no-cache-dir -r /tmp/requirements.cpu.txt \
    && { pip cache purge || true; }

COPY docker/requirements.api.txt /tmp/requirements.api.txt
RUN pip install --no-cache-dir -r /tmp/requirements.api.txt

RUN find /opt/conda -type d -name '__pycache__' -prune -exec rm -rf {} + \
    && find /opt/conda -type f \( -name '*.pyc' -o -name '*.a' \) -delete \
    && rm -rf /opt/conda/pkgs /root/.cache/pip

# ---------- runtime ----------
FROM debian:12-slim AS runtime

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    COSYVOICE_REPO_DIR=/opt/CosyVoice \
    PYTHONPATH=/opt/CosyVoice:/opt/CosyVoice/third_party/Matcha-TTS:/opt/api \
    PATH=/opt/conda/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

RUN apt-get update && apt-get install -y --no-install-recommends \
        ffmpeg sox libsox3 ca-certificates libgomp1 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /opt/conda /opt/conda
COPY --from=builder /opt/CosyVoice /opt/CosyVoice
COPY app /opt/api/app

WORKDIR /opt/api

VOLUME ["/voices", "/root/.cache"]
EXPOSE 8000

COPY docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
CMD ["uvicorn", "app.server:app", "--host", "0.0.0.0", "--port", "8000"]
