ARG CUDA_VERSION=12.4.1
ARG UBUNTU_VERSION=22.04

# ---------- builder ----------
FROM nvidia/cuda:${CUDA_VERSION}-cudnn-devel-ubuntu${UBUNTU_VERSION} AS builder

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    PATH=/opt/conda/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

RUN apt-get update && apt-get install -y --no-install-recommends \
        git build-essential wget unzip ca-certificates libsox-dev \
    && rm -rf /var/lib/apt/lists/*

RUN wget -q https://github.com/conda-forge/miniforge/releases/latest/download/Miniforge3-Linux-x86_64.sh -O /tmp/mf.sh \
    && bash /tmp/mf.sh -b -p /opt/conda \
    && rm /tmp/mf.sh

# cuda-nvcc is needed at runtime: DeepSpeed probes `nvcc -V` at import time
# to detect the system CUDA version (see deepspeed/ops/op_builder/builder.py).
# Installing it via conda lets it ride along with /opt/conda into the runtime
# stage without pulling in the full CUDA SDK.
RUN conda install -y -c nvidia -c conda-forge python=3.10 pynini==2.1.5 cuda-nvcc=12.4.* \
    && conda clean -afy

# openai-whisper==20231117's setup.py imports pkg_resources, which setuptools
# 81+ no longer ships. Pin below that and build it without isolation so it
# sees this setuptools instead of pip's fresh build env.
RUN pip install --no-cache-dir --upgrade pip "setuptools<81" wheel

COPY CosyVoice /opt/CosyVoice

RUN pip install --no-cache-dir --no-build-isolation openai-whisper==20231117 \
    && pip install --no-cache-dir -r /opt/CosyVoice/requirements.txt \
    && { pip cache purge || true; }

COPY docker/requirements.api.txt /tmp/requirements.api.txt
RUN pip install --no-cache-dir -r /tmp/requirements.api.txt

# Strip build artifacts that aren't needed at runtime.
RUN find /opt/conda -type d -name '__pycache__' -prune -exec rm -rf {} + \
    && find /opt/conda -type f \( -name '*.pyc' -o -name '*.a' \) -delete \
    && rm -rf /opt/conda/pkgs /root/.cache/pip

# ---------- runtime ----------
FROM nvidia/cuda:${CUDA_VERSION}-cudnn-runtime-ubuntu${UBUNTU_VERSION} AS runtime

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    COSYVOICE_REPO_DIR=/opt/CosyVoice \
    PYTHONPATH=/opt/CosyVoice:/opt/CosyVoice/third_party/Matcha-TTS:/opt/api \
    PATH=/opt/conda/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

RUN apt-get update && apt-get install -y --no-install-recommends \
        ffmpeg sox libsox3 ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /opt/conda /opt/conda
COPY --from=builder /opt/CosyVoice /opt/CosyVoice
COPY app /opt/api/app

# DeepSpeed calls ${CUDA_HOME}/bin/nvcc on import; the -runtime- base image
# lacks nvcc, so expose the copy installed into /opt/conda at that path.
RUN mkdir -p /usr/local/cuda/bin \
    && ln -s /opt/conda/bin/nvcc /usr/local/cuda/bin/nvcc

WORKDIR /opt/api

VOLUME ["/voices", "/root/.cache"]
EXPOSE 8000

COPY docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
CMD ["uvicorn", "app.server:app", "--host", "0.0.0.0", "--port", "8000"]
